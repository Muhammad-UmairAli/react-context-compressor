{
  "name": "react-context-compressor",
  "version": "0.2.1",
  "description": "Mechanical, zero-dependency client-side compressor + sanitizer that turns React/JS app state into a minimal, safe payload for LLMs.",
  "type": "module",
  "license": "MIT",
  "author": "Muhammad Umair Ali <claude@oxym.tech> (https://github.com/Muhammad-UmairAli)",
  "contributors": [
    "Muhammad Umair Ali <claude@oxym.tech> (https://github.com/Muhammad-UmairAli)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-UmairAli/react-context-compressor.git"
  },
  "homepage": "https://github.com/Muhammad-UmairAli/react-context-compressor#readme",
  "bugs": {
    "url": "https://github.com/Muhammad-UmairAli/react-context-compressor/issues"
  },
  "keywords": [
    "react",
    "llm",
    "ai",
    "context",
    "compression",
    "sanitize",
    "tokens",
    "state",
    "prompt"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.mjs"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "size": "size-limit",
    "attw": "attw --pack",
    "publint": "publint",
    "changeset": "changeset",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
